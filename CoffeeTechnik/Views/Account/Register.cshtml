@using CoffeeTechnik.ViewModels
@model RegisterViewModel

@{
    ViewData["Title"] = "Регистрация";
    var successMessage = TempData["SuccessMessage"] as string;
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow">
            <div class="card-body">

                <h3 class="text-center mb-4">Регистрация</h3>

                @if (!string.IsNullOrEmpty(successMessage))
                {
                    <div class="alert alert-success text-center">
                        @successMessage
                    </div>
                }

                <form asp-action="Register" method="post" novalidate>

                    <div class="mb-3">
                        <label asp-for="FirstName" class="form-label"></label>
                        <input asp-for="FirstName"
                               class="form-control @(ViewData.ModelState["FirstName"]?.Errors.Count > 0 ? "is-invalid" : "")" />
                        <span asp-validation-for="FirstName" class="invalid-feedback"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="LastName" class="form-label"></label>
                        <input asp-for="LastName"
                               class="form-control @(ViewData.ModelState["LastName"]?.Errors.Count > 0 ? "is-invalid" : "")" />
                        <span asp-validation-for="LastName" class="invalid-feedback"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="PhoneNumber" class="form-label"></label>
                        <input asp-for="PhoneNumber"
                               class="form-control @(ViewData.ModelState["PhoneNumber"]?.Errors.Count > 0 ? "is-invalid" : "")" />
                        <span asp-validation-for="PhoneNumber" class="invalid-feedback"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Username" class="form-label"></label>
                        <input asp-for="Username"
                               class="form-control @(ViewData.ModelState["Username"]?.Errors.Count > 0 ? "is-invalid" : "")" />
                        <span asp-validation-for="Username" class="invalid-feedback"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label"></label>
                        <input asp-for="Password"
                               type="password"
                               minlength="5"
                               class="form-control @(ViewData.ModelState["Password"]?.Errors.Count > 0 ? "is-invalid" : "")" />
                        <span asp-validation-for="Password" class="invalid-feedback"></span>
                    </div>

                    
                    <div class="mb-3">
                        <label asp-for="Role" class="form-label"></label>
                        <select asp-for="Role"
                                class="form-select @(ViewData.ModelState["Role"]?.Errors.Count > 0 ? "is-invalid" : "")">
                            <option value="">-- Избери роля --</option>
                            <option value="Admin">Администратор</option>
                            <option value="Technician">Техник</option>
                            <option value="Sales">Търговски представител</option>
                            <option value="Guest">Гост</option>
                        </select>
                        <span asp-validation-for="Role" class="invalid-feedback"></span>
                    </div>

                    <div class="d-flex justify-content-end">
                        <button type="submit" class="btn btn-primary">Регистрирай</button>
                    </div>

                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}