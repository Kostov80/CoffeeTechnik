@using CoffeeTechnik.ViewModels
@model DeleteObjectViewModel

@{
    ViewData["Title"] = "Изтрий обект";
}

<div class="container mt-4">
    <h2 class="text-center mb-4">Изтрий обект</h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success text-center">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger text-center">
            @TempData["ErrorMessage"]
        </div>
    }

    <form asp-action="DeleteObject" asp-controller="ServiceRequest" method="post">
        @Html.AntiForgeryToken()

        <div class="mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-danger">
            Изтрий обекта
        </button>
    </form>

    <a asp-action="Index" asp-controller="ServiceRequest" class="btn btn-secondary mt-3">
        Назад
    </a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}