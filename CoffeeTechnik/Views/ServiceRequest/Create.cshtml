@{
    ViewData["Title"] = "Нова заявка";
}

<div class="container mt-5 text-center">

    <h4 class="mb-4">Нова заявка</h4>

    <div class="d-flex flex-column align-items-center gap-3 mb-5">

        <a asp-controller="ServiceRequest"
           asp-action="CreateMontage"
           class="btn btn-outline-primary btn-lg w-50">
            Монтаж
        </a>

        <a asp-controller="ServiceRequest"
           asp-action="CreateDemontage"
           class="btn btn-outline-secondary btn-lg w-50">
            Демонтаж
        </a>

        <a asp-controller="ServiceRequest"
           asp-action="CreateEmergency"
           class="btn btn-outline-danger btn-lg w-50">
            Авария
        </a>

        <a asp-controller="ServiceRequest"
           asp-action="CreateMaintenance"
           class="btn btn-outline-success btn-lg w-50">
            Профилактика
        </a>

    </div>

</div>

<a asp-controller="ServiceRequest"
   asp-action="Index"
   class="btn btn-info"
   style="position: fixed; bottom: 20px; right: 20px; z-index: 1000;">
    Виж заявки
</a>

<a asp-controller="Home"
   asp-action="Index"
   class="btn btn-secondary"
   style="position: fixed; bottom: 20px; left: 20px; z-index: 1000;">
    ← Назад
</a>