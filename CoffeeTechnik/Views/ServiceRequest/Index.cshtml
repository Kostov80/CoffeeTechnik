@model IEnumerable<CoffeeTechnik.Models.ServiceRequest>

@{
    ViewData["Title"] = "Сервизна дейност";
    var role = Context.Session.GetString("UserRole") ?? "Guest";

    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    string currentFilter = ViewBag.CurrentFilter as string;
}

<div class="container mt-4">
    <h2 class="text-center mb-4">Сервизна дейност</h2>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success text-center">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger text-center">
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="d-flex justify-content-center mb-3 gap-3 flex-wrap">

        <div class="dropdown">
            <button class="btn btn-secondary dropdown-toggle" type="button"
                    data-bs-toggle="dropdown">
                Филтрирай по тип
            </button>
            <ul class="dropdown-menu">
                <li><a class="dropdown-item" asp-action="Index" asp-route-requestType="">Всички</a></li>
                <li><a class="dropdown-item" asp-action="Index" asp-route-requestType="Монтаж">Монтаж</a></li>
                <li><a class="dropdown-item" asp-action="Index" asp-route-requestType="Демонтаж">Демонтаж</a></li>
                <li><a class="dropdown-item" asp-action="Index" asp-route-requestType="Авария">Авария</a></li>
                <li><a class="dropdown-item" asp-action="Index" asp-route-requestType="Профилактика">Профилактика</a></li>
            </ul>
        </div>

        @if (role == "Sales" || role == "Technician")
        {
            <div class="dropdown">
                <button class="btn btn-primary dropdown-toggle" type="button"
                        data-bs-toggle="dropdown">
                    Нова заявка
                </button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" asp-action="CreateMontage">Монтаж</a></li>
                    <li><a class="dropdown-item" asp-action="CreateDemontage">Демонтаж</a></li>
                    <li><a class="dropdown-item" asp-action="CreateEmergency">Авария</a></li>
                    <li><a class="dropdown-item" asp-action="CreateMaintenance">Профилактика</a></li>
                </ul>
            </div>
        }
    </div>

    <table class="table table-bordered table-striped table-hover mt-3">
        <thead class="table-dark">
            <tr>
                <th>Обект</th>
                <th>Град</th>
                <th>Модел машина</th>
                <th>Тип</th>
                <th>Описание</th>
                <th>Дата</th>
                <th>Действия</th>
            </tr>
        </thead>

        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@(item.Machine?.ObjectEntity?.Name ?? "–")</td>
                        <td>@(item.Machine?.ObjectEntity?.City ?? "–")</td>
                        <td>@(item.Machine?.Model ?? "–")</td>
                        <td>@item.RequestType</td>
                        <td>@item.Description</td>
                        <td>@item.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                        <td class="d-flex gap-2 flex-wrap">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Details</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Редактирай</a>

                            <form asp-action="Delete" method="post"
                                  onsubmit="return confirm('Сигурни ли сте?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-danger btn-sm">Изтрий</button>
                            </form>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center">Няма въведени заявки.</td>
                </tr>
            }
        </tbody>
    </table>
        
    <div class="d-flex justify-content-center mt-4">
        <nav>
            <ul class="pagination">

                @if (currentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@(currentPage - 1)"
                           asp-route-requestType="@currentFilter">
                            Предишна
                        </a>
                    </li>
                }

                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@i"
                           asp-route-requestType="@currentFilter">
                            @i
                        </a>
                    </li>
                }

                @if (currentPage < totalPages)
                {
                    <li class="page-item">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@(currentPage + 1)"
                           asp-route-requestType="@currentFilter">
                            Следваща
                        </a>
                    </li>
                }

            </ul>
        </nav>
    </div>
</div>

@if (role == "Sales" || role == "Technician")
{
    <a asp-controller="Home" asp-action="Index"
       class="btn shadow"
       style="position: fixed; bottom: 20px; left: 20px; z-index:2000;
                  background-color: #6c757d; color:white; width:120px;">
        ← Назад
    </a>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}