@model IEnumerable<CoffeeTechnik.Models.InventoryItem>

@{
    ViewData["Title"] = "Части";
    var search = Context.Request.Query["searchString"];
}

<div class="container mt-4">

    <h2 class="text-center mb-4">Склад - Части</h2>

    <a asp-action="Index" class="btn btn-secondary mb-3">Назад</a>

    <a asp-action="CreatePart" class="btn btn-primary mb-3">Добави част</a>

    
    <form method="get" class="mb-3 d-flex gap-2">
        <input type="text"
               name="searchString"
               value="@search"
               placeholder="Търси част..."
               class="form-control" />

        <button type="submit" class="btn btn-dark">
            Търси
        </button>

        <a asp-action="Parts" class="btn btn-outline-secondary">
            Изчисти
        </a>
    </form>

    <table class="table table-striped table-hover shadow">
        <thead class="table-dark">
            <tr>
                <th>Част</th>
                <th>Бройка</th>
                <th>Описание</th>
                <th>Действия</th>
            </tr>
        </thead>

        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="4" class="text-center text-muted">
                        Няма намерени резултати
                    </td>
                </tr>
            }
            else
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@item.Quantity</td>
                        <td>@item.Description</td>

                        <td>
                            <a asp-action="EditPart"
                               asp-route-id="@item.Id"
                               class="btn btn-warning btn-sm">
                                Edit
                            </a>

                            <form asp-action="DeletePart"
                                  asp-route-id="@item.Id"
                                  method="post"
                                  style="display:inline;">

                                @Html.AntiForgeryToken()

                                <button type="submit"
                                        class="btn btn-danger btn-sm"
                                        onclick="return confirm('Сигурен ли си?');">
                                    Delete
                                </button>

                            </form>
                        </td>
                    </tr>
                }
            }
        </tbody>

    </table>

</div>