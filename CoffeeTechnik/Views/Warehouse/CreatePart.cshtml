@model CoffeeTechnik.Models.InventoryItem

@{
    ViewData["Title"] = "Добави част";
}

<div class="container mt-4">

    <h2>Добави част</h2>

    <form asp-action="CreatePart" method="post">
        @Html.AntiForgeryToken()

        <div class="form-group mb-3">
            <label asp-for="Name"></label>
            <input asp-for="Name" class="form-control" placeholder="Въведи име..." />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Quantity"></label>
            <input asp-for="Quantity" class="form-control" placeholder="Въведи количество..." />
            <span asp-validation-for="Quantity" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="Description"></label>
            <input asp-for="Description" class="form-control" placeholder="По желание..." />
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-success">Запази</button>
        <a asp-action="Parts" class="btn btn-secondary">Отказ</a>
    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}