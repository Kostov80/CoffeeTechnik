@model IEnumerable<CoffeeTechnik.Models.ViewModels.CoffeeMachineViewModel>

@{
    ViewData["Title"] = "Машини";
}

<h2>@ViewData["Title"]</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success mt-3">
        @TempData["SuccessMessage"]
    </div>
}

<div class="mb-3 mt-3">
    <a class="btn btn-success" asp-action="Create">Добави нова машина</a>
</div>

<table class="table table-striped table-hover shadow">
    <thead class="table-dark">
        <tr>
            <th>Модел</th>
            <th>Сериен номер</th>
            <th>Дата на инсталация</th>
            <th>Обект (ID)</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Any())
        {
            @foreach (var coffee in Model)
            {
                <tr>
                    <td>@coffee.Model</td>
                    <td>@coffee.SerialNumber</td>
                    <td>@coffee.InstallationDate?.ToString("dd.MM.yyyy")</td>
                    <td>@coffee.ObjectEntityId</td>
                    <td>
                        <a class="btn btn-sm btn-info me-1"
                           asp-action="Details"
                           asp-route-id="@coffee.Id">
                            Details
                        </a>

                        <a class="btn btn-sm btn-primary me-1"
                           asp-action="Edit"
                           asp-route-id="@coffee.Id">
                            Редактирай
                        </a>

                        <form asp-action="Delete"
                              asp-route-id="@coffee.Id"
                              method="post"
                              style="display:inline;">
                            @Html.AntiForgeryToken()

                            <button type="submit"
                                    class="btn btn-sm btn-danger"
                                    onclick="return confirm('Сигурни ли сте, че искате да изтриете тази машина?');">
                                Изтрий
                            </button>
                        </form>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="5" class="text-center text-muted">
                    Няма налични машини
                </td>
            </tr>
        }
    </tbody>
</table>