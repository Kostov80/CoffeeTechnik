@model CoffeeTechnik.Models.ViewModels.CoffeeMachineViewModel

@{
    ViewData["Title"] = "Добави машина";
}

<h2>@ViewData["Title"]</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success mt-3">
        @TempData["SuccessMessage"]
    </div>
}

<form asp-action="Create" method="post" class="mt-3">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label asp-for="Model" class="form-label"></label>
        <input asp-for="Model" class="form-control" />
        <span asp-validation-for="Model" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="SerialNumber" class="form-label"></label>
        <input asp-for="SerialNumber" class="form-control" />
        <span asp-validation-for="SerialNumber" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="InstallationDate" class="form-label"></label>
        <input asp-for="InstallationDate" type="date" class="form-control" />
        <span asp-validation-for="InstallationDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ObjectEntityId" class="form-label"></label>
        <input asp-for="ObjectEntityId" type="number" class="form-control" />
        <span asp-validation-for="ObjectEntityId" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-success">Добави</button>
    <a asp-action="Index" class="btn btn-secondary">Назад</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}